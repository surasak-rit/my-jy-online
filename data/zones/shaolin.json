    {
      "id": "npc_shaolin_sweeper",
      "at": {
        "x": 11,
        "y": 11
      },
      "role": "พระกวาดลานหอพระธรรม",
      "archetype": "monk",
      "name": "หลวงจีนไร้นาม",
      "wander": false,
      "line": "ผู้เฒ่ากวาดลานมาเจ็ดสิบปี… วิชาทั้งปวงล้วนงอกจากรากเดียว ผู้ฝึกแต่หมัดโดยไร้ปราณภายในกำกับ ย่อมเจ็บในไม่รู้ตัว เจ้าพร้อมรับคัมภีร์ขั้นสูงแล้วหรือ?"
    },
    {
      "id": "npc_shaolin_damo",
      "at": {
        "x": 7,
        "y": 8
      },
      "role": "เจ้าสำนักหอตักม้อ",
      "archetype": "monk",
      "name": "พระเสวียนเข่อ",
      "line": "หอตักม้อสืบทอดวิชาภายนอก (外功) — หมัดอรหันต์เป็นราก ต่อยอดเป็นฝ่ามือเวยถัวและพลองปราบมาร ผู้ใดรากหมัดไม่มั่น ฝ่ามือก็ไร้น้ำหนัก"
    },
    {
      "id": "npc_shaolin_drill",
      "at": {
        "x": 15,
        "y": 8
      },
      "role": "ครูฝึกลานหมัดหอหลอฮั่น",
      "archetype": "monk",
      "name": "พระคุยตี้",
      "line": "ศิษย์ใหม่ทุกคนเริ่มที่หมัดอรหันต์ ตีหมัดให้ครบพันครั้งต่อวัน รากฐานมั่นแล้วจึงค่อยพูดเรื่องวิชาสูง"
    },
    {
      "id": "npc_shaolin_discipline",
      "at": {
        "x": 5,
        "y": 6
      },
      "role": "เจ้าสำนักหอวินัย",
      "archetype": "monk",
      "name": "พระเจี้ยเฉิน",
      "line": "หอวินัยรับเฉพาะศิษย์ชายตามกฎอารามแต่โบราณ ผู้เข้าวัดต้องถือศีล สงบใจ มิเช่นนั้นแม้วิชาแกร่งก็พาตนเข้าสู่มารได้"
    }
